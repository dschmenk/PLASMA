//
// Debug
//
def assert(val, msg)#0
    if not val
        dhgrMode(DHGR_TEXT_MODE)
        puts(msg)
        getc
    fin
end
def stateExamine#0
    byte i
    dhgrMode(DHGR_TEXT_MODE)
    puts("Available Items: "); puti(hoardAvailable)
    puts("\nActive Items: "); puti(hoardActive)
    puts("\nRemaining Items: "); puti(hoardRemaining)
    puts("\nJackpots Left: "); puti(hoardJackpots)
    puts("\nTable Hoard\n")
    for i = 0 to TABLE_POSITIONS-1
        puti(hoardType[i]); putln
    next
    puts("Nerd Hoard\n")
    for i = 0 to NUM_NERDS-1
        puti(nerdHoard[i]); putln
    next
    puts("Halt")
    while (1); loop
end
//
// Utility Functions
//
def strcati(str, i)#0
    if i >= 10; strcati(str, i / 10); fin
    ^str++
    ^(str + (^str)) = (i % 10 + '0')
end
def itoa(str, i)#1
    ^str = 0
    if i < 0; ^str = 1; ^(str+1) = '-'; i = -i; fin
    strcati(str, i)
    return str
end
def atoi(strptr)#1
    var num, len, sign

    sign = 1
    num = 0
    len = ^strptr
    strptr++
    if ^strptr == '-'
        sign = -1
        strptr++
        len--
    elsif ^strptr == '+'
        strptr++
        len--
    fin
    while len and ^strptr >= '0' and ^strptr <= '9'
        num = num * 10 + ^strptr - '0'
        strptr++
        len--
    loop
    return num * sign
end
def wait(delay)#0
    while delay
        call($FCA8, 255, 0, 0, 0)
        delay--
    loop
end
//
// Input Functions
//
def getButtonKey#1
    byte input

    input = (^$C061 | ^$C062) & $80 // Look for either joystick button pushed
    if conio:keypressed() // Look for keypress
        input = input | (getc & $7F)
    fin
    return input
end
def waitButtonKey#0
    repeat
    until getButtonKey
end
def joyCalibrate#4
    byte x, y

    x, y, drop, drop = joyPos(0)
    if x < MAX_JOY and y < MAX_JOY
        return x / 2, (x + MAX_JOY) / 2, y / 2, (y + MAX_JOY) / 2 
    fin
    return 0, MAX_JOY, 0, MAX_JOY
end
//
// Load Assets
//
def loadTiles#0
    byte refnum

    refnum = fileio:open("TILES")
    if refnum
        tileList = heapAlloc(TILE_SIZE*NUM_TILES)
        if tileList and fileio:read(refnum, tileList, TILE_SIZE*NUM_TILES) <> TILE_SIZE*NUM_TILES
            heapRelease(tileList)
            tileList = NULL
            puts("Error reading tiles\n")
        fin
        fileio:close(refnum)
    fin
end
def loadSprites#0
    byte refnum, nerd, dir

    refnum = fileio:open("SPRITES")
    if refnum
        spriteList = heapAlloc(SPRITE_SIZE*NUM_SPRITES)
        if spriteList and fileio:read(refnum, spriteList, SPRITE_SIZE*NUM_SPRITES) <> SPRITE_SIZE*NUM_SPRITES
            heapRelease(spriteList)
            spriteList = NULL
            puts("Error reading sprites\n")
        fin
        fileio:close(refnum)
    fin
    //
    // Render nerds into tiles
    //
    for nerd = 0 to NUM_NERDS // Include Woz
        for dir = 0 to NUM_DIRS-1
            nerdBaseTile[nerd, dir] = heapAlloc(TILE_SIZE)
            dhgrSurfMem(OP_SRC, TILE_HEIGHT, nerdBaseTile[nerd, dir], TILE_SPAN)
            dcgrColor(CLR_LTBLUE)
            dhgrClearBl7(0, 0, TILE_WIDTH7, TILE_HEIGHT)
            dcgrPixMap(0, 2, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (HORDE_BASE + nerd*NUM_NERDS + dir)*SPRITE_SIZE)
        next
        for dir = 0 to NUM_DIRS-1
            nerdTile[nerd, dir] = heapAlloc(TILE_SIZE)
        next
    next
    dhgrSurfScr(OP_SRC)
end
//
// Drawing Functions
//
def drawFrame(x, y, w, h)#0
    byte r, b

    b = y+h-1
    r = x+w-1
    dcgrVLin(y, b, x)
    dcgrVLin(y, b, r)
    dcgrHLin(x, r, y)
    dcgrHLin(x, r, b)
end  
def drawItem(item)#0
    when item
        is 0
            dcgrStr(96,  76, "[P]lay")
            break
        is 1
            dcgrStr(96, 96, "[I]nfo")
            break
        is 2
            dcgrStr(96, 116, "[S]cores")
            break
        is 3
            dcgrStr(96, 136, "[Q]uit")
        wend
end
def drawSelect#0
    drawFrame(nerdPlayer*(TILE_WIDTH+4) + 64, 28, TILE_WIDTH+4, TILE_HEIGHT+4)
end
def drawName#0
    var nameSurf

    nameSurf = heapAlloc(9*4*10)
    dhgrSurfMem(OP_SRC, 10, nameSurf, 9*4)
    dcgrColor(CLR_PINK)
    dhgrClearBl7(0, 0, 9, 10)
    dcgrColor(CLR_BLACK)
    dcgrBoldStr(CLR_GREY, 30 - ^nerdName[nerdPlayer] * 2, 9, nerdName[nerdPlayer])
    dhgrSurfScr(OP_SRC)
    dhgrMemBl7(10,  16, 9, 10, nameSurf, 9*4)
    heapRelease(nameSurf)
end
def drawMenu#0
    byte i
    char[5] str

    dcgrColor(CLR_PINK)
    dhgrClearBl7(0, 0, SCR_WIDTH7, SCR_HEIGHT)
    dcgrColor(CLR_BLACK)
    dhgrClearBl7(1, 12, 7, 110)
    dhgrClearBl7(8, 66, 5, 56)
    dcgrColor(CLR_YELLOW)
    dhgrClearBl7(1, 122, 12, 63)
    dcgrRect(57, 68, 32, 12)
    dcgrColor(CLR_BROWN)
    dhgrClearBl7(6, 123, 2, 8)
    dhgrClearBl7(3, 144, 8, 28)
    dhgrClearBl7(5, 173, 4, 4)
    dcgrColor(CLR_BLACK)
    dcgrHLin(21, 76, 144)
    for i = 150 to 171 step 7
        dcgrColor(CLR_GREY1)
        dcgrHLin(21, 76, i)
        dcgrColor(CLR_BLACK)
        dcgrHLin(21, 76, i + 1)
    next
    for i = 21 to 77 step 4
        dcgrVLin(144, 172, i)
    next
    dcgrHLin(35, 62, 178)
    dcgrColor(CLR_GREY1)
    dcgrHLin(35, 62, 177)
    dcgrColor(CLR_WHITE)
    dcgrRect(21, 174, 2, 4)
    dcgrColor(CLR_AQUA)
    dhgrClearBl7(2, 35, 5, 58)
    dcgrVLin(37, 89, 13)
    dcgrVLin(37, 89, 49)
    dcgrVLin(39, 87, 12)
    dcgrVLin(39, 87, 50)
    dcgrColor(CLR_GREY2)
    dcgrRect(8, 14, 47, 12)
    dcgrColor(CLR_GREY1)
    drawFrame(8, 30, 47, 86)
    dcgrHLin(8, 54, 29)
    dcgrHLin(8, 54, 116)
    dcgrRect(11, 98, 40, 10)
    drawFrame(57, 82, 32, 35)
    dcgrRect(63, 97, 21, 4)
    dcgrRect(70, 95, 7, 2)
    dcgrRect(70, 101, 7, 2)
    drawFrame(10, 141, 78, 41)
    dcgrVLin(122, 184, 7)
    dcgrVLin(122, 184, 90)
    dcgrHLin(8, 89, 136)
    dcgrHLin(8, 89, 185)
    drawFrame(64-1, 28-1, 4*(TILE_WIDTH+4)+2, TILE_HEIGHT+4+2)
    for i = 0 to 3
        dcgrColor(nerdClr[i])
        dcgrRect(i*(TILE_WIDTH+4) + 64, 28, TILE_WIDTH+4, TILE_HEIGHT+4)
        dcgrPixMap(i*(TILE_WIDTH+4) + 64+2, 28+4, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (i*4+HORDE_BASE)*SPRITE_SIZE)
    next

    dcgrFont(FONT_DEF_THIN)
    dcgrStr(15, 44, ">")
    dcgrStr(15, 53, "SEAN'S")
    dcgrStr(15, 62, "GARAGE")
    dcgrStr(15, 71, "GIVEAWAY")
    dcgrStr(15, 80, ">")
    dcgrStr(92, 180, "8 bit shack")
    dcgrStr(96, 190, "2026 v")
    dcgrStr(120, 190, @ggVersion)
    dcgrColor(CLR_WHITE)
    dcgrBoldStr(CLR_BLACK, 110-24, 10, "Score:")
    dcgrColor(CLR_WHITE)
    dcgrBoldStr(CLR_BLACK, 110, 10, itoa(@str, totalScore))
    for i = 0 to 3; drawItem(i); next
    drawName
end
def drawLeaderBoard#0
    byte i
    char[4] str
    var leader

    dcgrColor(CLR_DRKBLUE)
    dhgrClearBl7(0, 0, SCR_WIDTH7, SCR_HEIGHT)
    dcgrColor(CLR_WHITE)
    dcgrBoldStr(CLR_BLACK, 70-20, 10, "Top Scores")
    leader = @leaderBoard
    dcgrColor(CLR_WHITE)
    for i = 1 to 10
        dcgrStr(i == 10 ?? 46 :: 50, i*12+20, itoa(@str, i))
        str[0] = 3
        str[1] = leader->initials[0]
        str[2] = leader->initials[1]
        str[3] = leader->initials[2]
        dcgrStr(62, i*12+20, @str)
        dcgrStr(82, i*12+20, itoa(@str, leader=>bestscore))
        leader = leader + t_leaders
    next
end
def drawMessage(msg)#0
    dhgrMemBl7(4*TILE_WIDTH7, 4*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_TABLEMID-1)*TILE_SIZE, TILE_SPAN)
    dhgrMemBl7(5*TILE_WIDTH7, 4*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_TABLEMID-1)*TILE_SIZE, TILE_SPAN)
    //dhgrMemBl7(6*TILE_WIDTH7, 4*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_TABLEMID-1)*TILE_SIZE, TILE_SPAN)
    if msg
        dcgrFont(FONT_DEF_THIN)
        dcgrColor(CLR_WHITE)
        dcgrStr(70 - ^msg * 2, 5*TILE_HEIGHT - 10, msg)
    fin
end
