    dcgrColor(CLR_WHITE)
    dhgrMemBl7(9*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_RIGHTBOARD-1)*TILE_SIZE, TILE_SPAN)
    dcgrStr(9*TILE_WIDTH, 15, @str)
end
def drawScore(nerd)#0
    char[4] str

    itoa(@str, nerdScore[nerd])
    dcgrColor(nerdClr[nerd])
    dcgrRect(nerdBoxX[nerd]*TILE_WIDTH+2, nerdBoxY[nerd]*TILE_HEIGHT+14, 8, 8)
    dcgrColor(CLR_WHITE)
    dcgrStr(nerdBoxX[nerd]*TILE_WIDTH+(nerdScore[nerd] > 9 ?? 1 :: 4), nerdBoxY[nerd]*TILE_HEIGHT+22, @str)
end
def drawMap#0
    var i, j, k, l
    char[4] lvlStr

    for j = TILEMAP_HEIGHT/2-1 downto 0
        for i = TILEMAP_WIDTH/2-1 downto 0
            l = TILEMAP_WIDTH-1 - i
            k = TILEMAP_HEIGHT-1 - j
            dhgrMemBl7(i*TILE_WIDTH7, j*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[j,i]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(l*TILE_WIDTH7, j*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[j,l]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(i*TILE_WIDTH7, k*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[k,i]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(l*TILE_WIDTH7, k*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[k,l]-1)*TILE_SIZE, TILE_SPAN)
        next
    next
    dcgrFont(FONT_DEF_THIN)
    dcgrColor(CLR_WHITE)
    dcgrStr(6*TILE_WIDTH+4, 15, "LVL")
    dcgrStr(6*TILE_WIDTH+16, 15, itoa(@lvlStr, NUM_LEVELS+1 - level))
    dcgrStr(6*TILE_WIDTH+28, 15, "REM")
end
def rndQuote#0
    byte i
    byte strX, strY, extX, extY
    var msg

    msg = @loserText
    i = conio:rnd() % NUM_QUOTES
    while i
        msg = msg + ^msg + 1
        i--
    loop
    strY = 5*TILE_HEIGHT - 10
    extX, extY = dcgrStrExtents(msg)
    strX = 70 - (extX + 1)/2
    dcgrColor(CLR_BLACK)
    dcgrRect(strX - 1, strY - extY - 1, extX + 4, extY + 3)
    dcgrRect(strX - 2, strY - extY    , extX + 6, extY + 1)
    dcgrColor(CLR_WHITE)
    dcgrStr(strX, strY, msg)
    if soundOn; conio:tone(100, 20); else wait(5); fin
    if soundOn; conio:tone(75, 30); else wait(5); fin
    if soundOn; conio:tone(100, 40); else wait(5); fin
    i = 20
    while i and not getButtonKey
        wait(1)
        i--
    loop
end
def resetNerdTiles(nerd)#0
    memcpy(nerdTile[nerd, 0], nerdBaseTile[nerd, 0], TILE_SIZE*NUM_DIRS)
end
def signNerdTiles(nerd)#0
    byte dir, clrBack

    clrBack = hoardClr[(nerdHoard[nerd] & $7F)-1] ^ CLR_GREY
    for dir = 0 to NUM_DIRS-1
        dhgrSurfMem(OP_SRC, TILE_HEIGHT, nerdTile[nerd, dir], TILE_SPAN)
        //
        // Sign hoard to memory surface
        //
        dcgrColor(clrBack)
        dcgrStr(4, 18, "W")
    next
    dhgrSurfScr(OP_SRC)
end
def updateNerdTiles(nerd)#0
    byte dir, clrFore, clrBack

    clrFore = hoardClr[(nerdHoard[nerd] & $7F)-1]
    clrBack = hoardClr[(nerdHoard[nerd] & $7F)-1] ^ CLR_GREY
    for dir = 0 to NUM_DIRS-1
        dhgrSurfMem(OP_SRC, TILE_HEIGHT, nerdTile[nerd, dir], TILE_SPAN)
        //
        // Draw nerd + any hoard to memory surface the size of a tile
        //
        //dcgrPixMap(0, 0, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + ((nerdHoard[nerd] & $7F) + HOARD_BASE)*SPRITE_SIZE)
        dcgrColor(clrFore)
        dcgrRect(3, 10, 7, 8)
        dcgrColor(clrBack)
        drawFrame(2, 9, 9, 10)
    next
    if nerdHoard[nerd] & SIGNED
        signNerdTiles(nerd)
    fin
    dhgrSurfScr(OP_SRC)
end
//
// Drawing and Sound F/X Actions
//
def actionClearMessage(event)#0
    drawMessage(NULL)
    eventFree(event)
end
def actionSeanSit(event)#0
    dhgrMemBl7(SEAN_X*TILE_WIDTH7,     SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN1-1)*TILE_SIZE, TILE_SPAN)
    dhgrMemBl7((SEAN_X+1)*TILE_WIDTH7, SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN2-1)*TILE_SIZE, TILE_SPAN)
    eventFree(event)
end
def actionSFX(event)#0
    byte sfxTable, sfxIndex

    sfxIndex = event->evParam.1
    sfxTable = event->evParam.0
    buzz = sfxList.[sfxTable, sfxIndex]
    if buzz
        event->evParam.1 = sfxIndex + 1
        addEvent(1, event)
    else
        if sfxTable == SFX_BUMP
            bumping = FALSE
        fin
        eventFree(event)
    fin
end
//
// The Hard Stuff
//
def hitCheck(nerd, x, y)#1
    byte i

    if x < 0 or x >= TILEMAP_WIDTH or y >= TILEMAP_HEIGHT; return HIT_TILE; fin // Quick test for edges
    when tileMap.[y, x]
        is TILE_FLOOR
            //
            // Check for other nerds
            //
            for i = 0 to NUM_NERDS
                if x == nerdX[i] and y == nerdY[i]
                    if i == WOZ and nerdHoard[nerd] and nerdHoard[nerd] < JACKPOT // Sign item?
                        signNerdTiles(nerd)
                        nerdHoard[nerd] = nerdHoard[nerd] | SIGNED
                        addAction(1, @actionSFX, SFX_SIGN)
                        addAction(100, @actionClearMessage, 0)
                        drawMessage("Signed")
                    elsif nerd == nerdPlayer and (btn0 | btn1) & $80 and \
                        not nerdHoard[nerd] and nerdHoard[i] and nerdScore[nerd] <= nerdScore[i] // Steal?
                        nerdHoard[nerd] = nerdHoard[i]
                        nerdHoard[i]    = 0
                        resetNerdTiles(i)
                        updateNerdTiles(nerd)
                        addAction(1, @actionSFX, SFX_STEAL)
                        moveNerd(i, MOVE_NONE) // Draw stealee without hoard
                    else
                        if not bumping // Don't overload bumping sound effects
                            bumping = TRUE
                            addAction(1, @actionSFX, SFX_BUMP)
                        fin
                    fin
                    return HIT_NERD
                fin
            next
            return HIT_NOTHING
        is TILE_BOX
            //
            // Drop off hoard?
            //
            if x == nerdBoxX[nerd] and y == nerdBoxY[nerd] and nerdHoard[nerd]
                hoardActive--
                nerdScore[nerd]++
                if nerdHoard[nerd] & SIGNED
                    nerdScore[nerd]++
                    addAction(1, @actionSFX, SFX_SCORE2)
                else
                    addAction(1, @actionSFX, SFX_SCORE)
                fin
                nerdHoard[nerd] = 0
                drawScore(nerd)
                resetNerdTiles(nerd)
            fin
            break
        is TILE_SEAN1
        is TILE_SEAN2
            //
            // Jackpot?
            //
            if nerdHoard[nerd] == JACKPOT
                hoardActive--
                nerdHoard[nerd] = 0
                nerdScore[nerd] = nerdScore[nerd] + 3
                drawScore(nerd)
                addAction(1, @actionSFX, SFX_JACKPOT)
                addAction(100, @actionSeanSit, 0)
                addAction(100, @actionClearMessage, 0)
                drawMessage("Jackpot")
                dhgrMemBl7(SEAN_X*TILE_WIDTH7,     SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN3-1)*TILE_SIZE, TILE_SPAN)
                dhgrMemBl7((SEAN_X+1)*TILE_WIDTH7, SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN4-1)*TILE_SIZE, TILE_SPAN)
                resetNerdTiles(nerd)
            fin
            break
        is TILE_OPENDOOR1
        is TILE_OPENDOOR2
            //
            // Nerd exit level
            //
            dcgrColor(CLR_LTBLUE) // Erase nerd
            dhgrClearBl7(nerdX[nerd] * TILE_WIDTH7, nerdY[nerd] * TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT)
            nerdY[nerd] = 0
            return HIT_EXIT
            break
        otherwise
            //
            // Table ?
            //
            if nerd < WOZ // Don't let Woz pick up items
                for i = 0 to TABLE_POSITIONS-1
                    if tablePosX[i] == x and tablePosY[i] == y
                        if hoardType[i] and nerdHoard[nerd] <> JACKPOT // Pick up HW (but avoid swapping out jackpot)
                            dhgrMemBl7(x*TILE_WIDTH7, y*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[y,x]-1)*TILE_SIZE, TILE_SPAN)
                            if nerdHoard[nerd]; resetNerdTiles(nerd); fin
                            nerdHoard[nerd], hoardType[i] = hoardType[i], nerdHoard[nerd] // Swap goods
                            updateNerdTiles(nerd)
                            if hoardType[i]
                                dcgrPixMap(tablePosX[i] * TILE_WIDTH,       \
                                            tablePosY[i] * TILE_HEIGHT + 2, \
                                            SPRITE_WIDTH, SPRITE_HEIGHT,    \
                                            spriteList + ((hoardType[i] & $7F) - 1) * SPRITE_SIZE)
                            else
                                hoardAvailable--
                            fin
                            addAction(1, @actionSFX, SFX_PICKUP)
                        fin
                        return HIT_TILE
                    fin
                next
            fin
    wend
    return HIT_TILE
end
def mapZone(x, y)#1
    byte zone

    zone = 0
    if x < 3 or (x == 3 and (y >= 3 and y <= 5)) // Include table left edge
        zone = ZONE_WEST
    elsif x > 6 or (x == 6 and (y >= 3 and y <= 5)) // Include table right edge
        zone = ZONE_EAST
    fin
    if y < 3 or (y == 3 and (x >= 3 and x <= 6)) // Include table top edge
        zone = zone | ZONE_NORTH
    elsif y > 5 or (y == 5 and (x >= 3 and x <= 6)) // Include table bottom edge
        zone = zone | ZONE_SOUTH
    fin
    return zone
end
def moveNerd(nerd, dir)#1
    byte oldX, oldY
    var moved

    oldX  = nerdX[nerd]
    oldY  = nerdY[nerd]
    moved = FALSE
    when dir
        is MOVE_UP
            if not hitCheck(nerd, nerdX[nerd], nerdY[nerd] - 1)
                nerdY[nerd]--
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_AWAY
            break
        is MOVE_LEFT
            if nerdX[nerd] > 0 and not hitCheck(nerd, nerdX[nerd] - 1, nerdY[nerd])
                nerdX[nerd]--
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_LEFT
            break
        is MOVE_RIGHT
            if nerdX[nerd] < 9 and not hitCheck(nerd, nerdX[nerd] + 1, nerdY[nerd])
                nerdX[nerd]++
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_RIGHT
            break
        is MOVE_DOWN
            if nerdY[nerd] < 7 and not hitCheck(nerd, nerdX[nerd], nerdY[nerd] + 1)
                nerdY[nerd]++
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_FORWARD
            break
    wend
    if moved
        //
        // Erase previous position
        //
        dcgrColor(CLR_LTBLUE)
        dhgrClearBl7(oldX * TILE_WIDTH7, oldY * TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT)
    fin
    //
    // Update nerd on screen
    //
    dhgrMemBl7(nerdX[nerd] * TILE_WIDTH7,  nerdY[nerd] * TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, nerdTile[nerd, nerdDir[nerd]], TILE_SPAN)
    return moved
end
def addHoard#0
    byte pos

    if hoardRemaining and hoardAvailable < TABLE_POSITIONS
        pos = conio:rnd() % TABLE_POSITIONS
        while hoardType[pos]
            pos++; if pos == TABLE_POSITIONS; pos = 0; fin
        loop
        if hoardJackpots
            if hoardJackpots >= hoardRemaining
                hoardType[pos] = JACKPOT
            else
                hoardType[pos] = ((conio:rnd() & 255) < 25) ?? JACKPOT :: (conio:rnd() & HOARD_NUM-2) + 1
            fin
            if hoardType[pos] == JACKPOT
                hoardJackpots--
            fin
        else
            hoardType[pos] = (conio:rnd() & HOARD_NUM-2) + 1
        fin
        hoardActive++
        hoardAvailable++
        hoardRemaining--
        dcgrPixMap(tablePosX[pos] * TILE_WIDTH, tablePosY[pos]*TILE_HEIGHT+2, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (hoardType[pos] - 1) * SPRITE_SIZE)
        drawStatus
    fin
end
def navigateNerd(nerd, targetX, targetY)#0
    byte moveDir, nerdZone, targetZone
    var distX, distY

    distX      = targetX - nerdX[nerd]
    distY      = targetY - nerdY[nerd]
    nerdZone   = mapZone(nerdX[nerd], nerdY[nerd])
    targetZone = mapZone(targetX, targetY)
    if nerdZone & targetZone
        //
        // Same zone - move to target linearly
        //
        if distX * distX > distY * distY
            moveDir = distX < 0 ??  MOVE_LEFT :: MOVE_RIGHT
        else
            moveDir = distY < 0 ?? MOVE_UP :: MOVE_DOWN                    
        fin
    else
        //
        // Have to move around table
        //
        if nerdZone & (ZONE_EAST | ZONE_WEST)
            moveDir = targetY < TILEMAP_HEIGHT/2 ?? MOVE_UP :: MOVE_DOWN
        elsif nerdZone & (ZONE_NORTH | ZONE_SOUTH)
            moveDir = targetX < TILEMAP_WIDTH/2 ?? MOVE_LEFT :: MOVE_RIGHT
        fin
    fin
    if not moveNerd(nerd, moveDir) and (distX * distX + distY * distY) > 1
        if moveDir == MOVE_LEFT or moveDir == MOVE_RIGHT // Moving diagonal can be problematic
            moveDir = distY < 0 ?? MOVE_UP :: MOVE_DOWN                    
        else
            moveDir = distX < 0 ??  MOVE_LEFT :: MOVE_RIGHT
        fin
        if not moveNerd(nerd, moveDir)
            moveNerd(nerd, conio:rnd() & MOVE_MASK) // Help get unstuck
        fin
    fin
end
//
// Game Actions
//
def actionUpdateHoard(event)#0
    //
    // Add hoard to table at random time
    //
    addHoard
    if hoardRemaining
        addEvent(conio:rnd() % (level * HOARD_SCALE + HOARD_EQ), event)
    else
        eventFree(event)
    fin
end
def actionUpdateNerd(event)#0
    byte nerd, i
    byte targetX, targetY, nerdZone, targetZone
    var nearest, dist, distX, distY

    //
    // Move NPC
    //
    nerd = event->evParam
    if nerdHoard[nerd]
        //
        // Head for NPCs collection box unless jackpot
        //
        if nerdHoard[nerd] == JACKPOT
            targetX = nerdX[nerd] >= TILEMAP_WIDTH/2 ?? SEAN_X + 1 :: SEAN_X
            targetY = SEAN_Y
        else
            targetX = nerdBoxX[nerd]
            targetY = nerdBoxY[nerd]
            for i = 0 to TABLE_POSITIONS-1
                if hoardType[i] == JACKPOT // Always go for the jackpot
                    targetX = tablePosX[i]
                    targetY = tablePosY[i]
                    break
                fin
            next
        fin
    else
        //
        // Head for nearest table position with booty
        //
        nearest = 1000
        for i = 0 to TABLE_POSITIONS-1
            if hoardType[i]
                if hoardType[i] == JACKPOT // Always go for the jackpot
                    nearest = 0
                    targetX = tablePosX[i]
                    targetY = tablePosY[i]
                    break
                fin
                distX = tablePosX[i] - nerdX[nerd]
                distY = tablePosY[i] - nerdY[nerd]
                dist  = distX * distX + distY * distY
                if dist < nearest
                    nearest = dist
                    targetX = tablePosX[i]
                    targetY = tablePosY[i]
                fin
            fin
        next
        if nearest == 1000
            //
            // Wander aimlessly with nothing to go for
            //
            targetX = conio:rnd() % TILEMAP_WIDTH
            targetY = conio:rnd() % TILEMAP_HEIGHT
        fin
    fin
    //
    // Find best way to target
    //
    navigateNerd(nerd, targetX, targetY)
    addEvent(level2 * HORDE_MULSCALE / HORDE_DIVSCALE + HORDE_EQ, event)
end
def actionUpdateWoz(event)#0
    byte nerd, moveDir, i
    byte targetX, targetY, nerdZone, targetZone
    var nearest, dist, distX, distY

    //
    // Woz aimlessly wanders around
    //
    moveNerd(WOZ, conio:rnd() & MOVE_MASK)
    addEvent(WOZ_MOVE, event)
end
def actionUpdatePlayer(event)#0
    byte moveDir

    moveDir = MOVE_NONE
    if conio:keypressed()
        when toupper(conio:getkey())
            is keyArrowUp
            is 'I'
            is 'W'
                moveDir = MOVE_UP
                break
            is keyArrowLeft
            is 'J'
            is 'A'
                moveDir = MOVE_LEFT
                break
            is keyArrowRight
            is 'L'
            is 'D'
                moveDir = MOVE_RIGHT
                break
            is keyArrowDown
            is 'K'
            is 'S'
                moveDir = MOVE_DOWN
                break
            is 'C' // Recalibrate joystick on the fly
                joyLeft, joyRight, joyUp, joyDown = joyCalibrate
                break
            is 'P' // Pause
            is keyEscape // Pause
                drawMessage("Pause")
                waitButtonKey
                drawMessage(NULL)
                break
            //is 'X' // Examine state
            //    stateExamine
            //    break
            is keyCtrlS
                soundOn = not soundOn
                break
            is keyCtrlQ
                hoardActive = 0; hoardRemaining = 0; quit = TRUE
        wend
    else
        if altJoyDir & 1 // Alternate joystick direction priority
            if joyY < joyUp
                moveDir = MOVE_UP
            elsif joyY > joyDown
                moveDir = MOVE_DOWN
            fin
            if joyX < joyLeft
                moveDir = MOVE_LEFT
            elsif joyX > joyRight
                moveDir = MOVE_RIGHT
            fin
        else
            if joyX < joyLeft
                moveDir = MOVE_LEFT
            elsif joyX > joyRight
                moveDir = MOVE_RIGHT
            fin
            if joyY < joyUp
                moveDir = MOVE_UP
            elsif joyY > joyDown
                moveDir = MOVE_DOWN
            fin
        fin
        altJoyDir++
    fin
    moveNerd(nerdPlayer, moveDir)
    addEvent(level * PLAYER_MULSCALE / PLAYER_DIVSCALE + PLAYER_EQ, event)
end
def actionDemo(event)#0
    if conio:keypressed()
        when toupper(conio:getkey())
            is keyCtrlS
                soundOn = not soundOn
                break
            is keyEscape
            is keyCtrlQ
                hoardActive = 0; hoardRemaining = 0; quit = TRUE
                break
            is 'X' // Examine state
                stateExamine
                break
        wend
    fin
    addEvent(HORDE_EQ + PLAYER_EQ, event)
end
def actionExitNerd(event)#0
    byte nerd

    nerd = event->evParam
    navigateNerd(nerd, DOOR_X + 1, DOOR_Y)
    if nerdY[nerd] == 0 // Exit?
        dhgrMemBl7(DOOR_X*TILE_WIDTH7,     SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_OPENDOOR1-1)*TILE_SIZE, TILE_SPAN)
        dhgrMemBl7((DOOR_X+1)*TILE_WIDTH7, SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_OPENDOOR2-1)*TILE_SIZE, TILE_SPAN)
        exit--
    else
        addEvent(EXIT_MOVE, event)
    fin
end
def playGG#0
    //
    // Initialize event system
    //
    eventInit
    //
    // Show playing field
    //
    drawMap
    //
    // Intitialize horde
    //
    level2 = level * level
    args = (level2 * HORDE_MULSCALE / HORDE_DIVSCALE + HORDE_EQ) / 3
    for buzz = 0 to NUM_NERDS-1
        if nerdRandomize
            repeat
                params.0 = conio:rnd() % TILEMAP_WIDTH
                params.1 = conio:rnd() % TILEMAP_HEIGHT
            until hitCheck(buzz, params.0, params.1) == HIT_NOTHING
            nerdX[buzz]   = params.0
            nerdY[buzz]   = params.1
            nerdDir[buzz] = conio:rnd() & 3
        else
            when buzz
                is 0
                    nerdX[buzz]   = 1
                    nerdY[buzz]   = 1
                    nerdDir[buzz] = LOOK_RIGHT
                    break
                is 1
                    nerdX[buzz]   = 1
                    nerdY[buzz]   = TILEMAP_HEIGHT-1
                    nerdDir[buzz] = LOOK_RIGHT
                    break
                is 2
                    nerdX[buzz]   = TILEMAP_WIDTH-2
                    nerdY[buzz]   = 1
                    nerdDir[buzz] = LOOK_LEFT
                    break
                is 3
                    nerdX[buzz]   = TILEMAP_WIDTH-2
                    nerdY[buzz]   = TILEMAP_HEIGHT-1
                    nerdDir[buzz] = LOOK_LEFT
                    break
                wend
        fin
        nerdHoard[buzz] = 0
        nerdScore[buzz] = 0
        drawScore(buzz)
        resetNerdTiles(buzz)
        moveNerd(buzz, MOVE_NONE)
        if buzz == nerdPlayer
            addAction(level * PLAYER_MULSCALE / PLAYER_DIVSCALE + PLAYER_EQ + buzz, @actionUpdatePlayer, buzz)
        else
            addAction(args + buzz, @actionUpdateNerd, buzz)
            args = args + (level2 * HORDE_MULSCALE / HORDE_DIVSCALE + HORDE_EQ) / 3
        fin
    next
    nerdX[WOZ] = 0
    nerdY[WOZ] = 0
    if level <= NUM_LEVELS/2 // Add Woz to the upper levels
        repeat
            params.0 = conio:rnd() % TILEMAP_WIDTH
            params.1 = conio:rnd() % TILEMAP_HEIGHT
        until hitCheck(WOZ, params.0, params.1) == HIT_NOTHING
        nerdX[WOZ] = params.0
        nerdY[WOZ] = params.1
        nerdDir[WOZ] = conio:rnd() & 3
        resetNerdTiles(WOZ)
        moveNerd(WOZ, MOVE_NONE)
        addAction(WOZ_MOVE, @actionUpdateWoz, 0)
    fin
    if nerdPlayer > NUM_NERDS-1; addAction(args, @actionDemo, 0); fin
    //
    // Initialize hoard
    //
    for buzz = 0 to TABLE_POSITIONS-1
        hoardType[buzz] = 0
    next
    hoardActive    = 0
    hoardAvailable = 0
    hoardRemaining = HOARD_MINSIZE + NUM_LEVELS - level
    hoardJackpots  = hoardRemaining / 10
    for buzz = 0 to hoardRemaining / 5
        addHoard
    next
    addAction(level * HOARD_SCALE + HOARD_EQ, @actionUpdateHoard, 0)
    //
    // Go!
    //
    drawMessage("Ready")
    if soundOn; conio:tone(50, 40); else wait(5); fin
    drawMessage("Set")
    if soundOn; conio:tone(50, 40); else wait(5); fin
    drawMessage("Go!")
    if soundOn; conio:tone(60, 10); else wait(5); fin
    drawMessage(NULL)
    buzz = 0
    while hoardActive or hoardRemaining
        //
        // Sound/joystick
        //
        joyX, joyY, btn0, btn1 = joyPos(buzz & soundOn)
        //
        // Check event queue
        //
        doEvents
    loop
    //
    // Mkae sure Sean is sitting
    //
    dhgrMemBl7(SEAN_X*TILE_WIDTH7,     SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN1-1)*TILE_SIZE, TILE_SPAN)
    dhgrMemBl7((SEAN_X+1)*TILE_WIDTH7, SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN2-1)*TILE_SIZE, TILE_SPAN)
    //
    // Ending animation
    //
    if quit
        drawMessage("Quitter!")
    else
        //
        // Nerds head for exit
        //
        drawMessage(level > 1 ?? "Next Level!" :: "Finished!")
        //
        // Open garage door
        //
        dcgrColor(CLR_MEDBLUE)
        for buzz = 19 downto 6
            dcgrHLin(2, 25, buzz)
            if soundOn; conio:tone(10, 100); else wait(1); fin
        next
        tileMap.[DOOR_Y, DOOR_X]   = TILE_OPENDOOR1
        tileMap.[DOOR_Y, DOOR_X+1] = TILE_OPENDOOR2
        dhgrMemBl7(DOOR_X*TILE_WIDTH7,     SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_OPENDOOR1-1)*TILE_SIZE, TILE_SPAN)
        dhgrMemBl7((DOOR_X+1)*TILE_WIDTH7, SEAN_Y, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_OPENDOOR2-1)*TILE_SIZE, TILE_SPAN)
        //
        // File everyone out
        //
        eventInit
        exit = NUM_NERDS
        if level <= NUM_LEVELS/2; exit++; fin // Add Woz to the upper levels
        for buzz = 0 to exit-1
            addAction(1, @actionExitNerd, buzz)
        next
        while exit
            doEvents
        loop
        //
        // Close garage door
        //
        tileMap.[DOOR_Y, DOOR_X]   = TILE_DOOR1
        tileMap.[DOOR_Y, DOOR_X+1] = TILE_DOOR2
        //
        // Update total score
        //
        if nerdPlayer < NUM_NERDS
            totalScore = totalScore + nerdScore[nerdPlayer] // Add to total score if not demo
        fin
    fin
    if soundOn
        conio:tone(30, 20)
        conio:tone(200, 10)
        wait(5)
    fin
    getButtonKey
end
//
// Top Scores
//
def loadLeaderBoard#0
    byte refnum

    refnum = fileio:open(@leaderFile)
    if refnum
        fileio:read(refnum, @leaderBoard, t_leaders*10)
        fileio:close(refnum)
    fin
end
def storeLeaderBoard#0
    byte refnum

    fileio:destroy(@leaderFile)
    fileio:create(@leaderFile, $06, $0000)
    refnum = fileio:open(@leaderFile)
    if refnum
        fileio:write(refnum, @leaderBoard, t_leaders*10)
        fileio:close(refnum)
    fin
end
def updateLeaderBoard#1
    byte pulse, pos, key
    var leader
    byte[2] initial

    if conio:keypressed(); getc; fin // Clear any pending keypresses
    for leader = 0 to 9
        if *(@leaderBoard + leader * t_leaders + bestscore) < totalScore; break; fin
    next
    if leader == 10 or nerdPlayer > 3; return FALSE; fin
    conio:tone(10, 40)
    wait(1)
    conio:tone(20,  30)
    conio:tone(20,  30)
    conio:tone(300, 5)
    memcpy(@leaderBoard + (leader + 1) * t_leaders, @leaderBoard + leader * t_leaders, (9 - leader) * t_leaders)
    leader = @leaderBoard + leader * t_leaders
    leader->initials[0] = '_'
    leader->initials[1] = '_'
    leader->initials[2] = '_'
    leader=>bestscore  = totalScore
    dcgrColor(CLR_BLACK)
    dhgrClearBl7(3*TILE_WIDTH7, 3*TILE_HEIGHT, TILE_WIDTH7*5, TILE_HEIGHT*3)
    dcgrFont(FONT_DEF_THIN)
    dcgrColor(CLR_AQUA)
    dcgrBoldStr(CLR_MAGENTA, 5*TILE_WIDTH+TILE_WIDTH/2 - 15 * 2, 5*TILE_HEIGHT - 28, "Enter Initials")
    dcgrColor(CLR_WHITE)
    dcgrStr(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2, 5*TILE_HEIGHT - 8, "_ _ _")
    initial[0] = 1
    initial[1] = leader->initials[0]
    pos        = 0
    repeat
        dcgrColor(pulse)
        dcgrStr(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 8, @initial)
        pulse++
        key = 0
        if conio:keypressed()
            key = toupper(getc)
        else
            joyX, joyY, btn0, btn1 = joyPos(0)
            if joyX > joyRight
                key = initial[1]
                wait(2)
                if conio:keypressed(); getc; fin
            fin
            if joyY < joyUp
                dcgrColor(CLR_BLACK)
                dcgrRect(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 16, 4, 8)
                initial[1]++; if initial[1] < 'A' or initial[1] > 'Z'; initial[1] = 'A'; fin
                leader->[pos] = initial[1]
                wait(1)
                if conio:keypressed(); getc; fin
            elsif joyY > joyDown
                dcgrColor(CLR_BLACK)
                dcgrRect(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 16, 4, 8)
                initial[1]--; if initial[1] < 'A' or initial[1] > 'Z'; initial[1] = 'Z'; fin
                leader->[pos] = initial[1]
                wait(1)
                if conio:keypressed(); getc; fin
            fin
            if btn0 or btn1
                key = keyEnter
            fin
        fin
        if key >= 'A' and key <= 'Z'
            initial[1] = key
            leader->initials[pos] = key
            dcgrColor(CLR_BLACK)
            dcgrRect(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 16, 4, 8)
            dcgrColor(CLR_WHITE)
            dcgrStr(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 8, @initial)
            pos++
            if pos > 2; pos = 0; fin
            initial[1] = leader->initials[pos]
        fin
    until key == keyEnter
    storeLeaderBoard
    return TRUE
end
//
// Menu Interface
//
def scores#0
    res[TILE_SIZE] wozTile
    byte y, yDir

    drawLeaderBoard
    dhgrSurfMem(OP_SRC, TILE_HEIGHT, @wozTile, TILE_SPAN)
    dcgrColor(CLR_DRKBLUE)
    dhgrClearBl7(0, 0, TILE_WIDTH7, TILE_HEIGHT)
    dcgrPixMap(0, 2, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (HORDE_BASE + WOZ*4)*SPRITE_SIZE)
    dhgrSurfScr(OP_SRC)
    y    = 20
    yDir = 1
    repeat
        dhgrMemBl7(2 * TILE_WIDTH7, y, TILE_WIDTH7, TILE_HEIGHT, @wozTile, TILE_SPAN)
        dhgrMemBl7(7 * TILE_WIDTH7, y, TILE_WIDTH7, TILE_HEIGHT, @wozTile, TILE_SPAN)
        y = y + yDir
        if y < 10 or y > 130; yDir = -yDir; fin
    until getButtonKey
    drawMenu
end
def info#0
    screenRead("GGINFO.DHGR")    
    waitButtonKey
    drawMenu
end
def thankyou#0
    byte strX, strY, extX, extY
    var str

    dcgrColor(CLR_DRKGREEN)
    dhgrClearBl7(0, 0, SCR_WIDTH7, SCR_HEIGHT)
    str  = @Thanks
    strY = 10
    while ^str and strY < 192
        extX, extY = dcgrStrExtents(str)
        strX = 1 //70 - (extX + 1)/2
        dcgrColor(CLR_BLACK)
        dcgrBoldStr(CLR_WHITE, strX, strY, str)
        strY = strY + extY + 2
        str = str + ^str + 1
    loop
    waitButtonKey
    drawMenu
end
def menu
    byte item, pulse, key

    if nerdPlayer > NUM_NERDS-1; nerdPlayer = 0; fin
    drawMenu
    item = 0
    if conio:keypressed(); getc; fin // Clear any pending keypresses
    while TRUE
        dcgrColor(pulse >> 1)
        drawItem(item)
        drawSelect
        //
        // Handle user input
        //
        key = 0
        if conio:keypressed()
            key = toupper(getc)
        else
            joyX, joyY, btn0, btn1 = joyPos(0)
            if joyX < joyLeft
                key = keyArrowLeft
                if conio:keypressed(); getc; fin
            elsif joyX > joyRight
                key = keyArrowRight
                if conio:keypressed(); getc; fin
            fin
            if joyY < joyUp
                key = keyArrowUp
                wait(2)
                if conio:keypressed(); getc; fin
            elsif joyY > joyDown
                key = keyArrowDown
                wait(2)
                if conio:keypressed(); getc; fin
            fin
            if btn0 or btn1
                key = keyEnter
            fin
        fin
        when key
            is keyArrowLeft
                dcgrColor(nerdClr[nerdPlayer])
                drawSelect
                nerdPlayer = (nerdPlayer - 1) & (NUM_NERDS - 1)
                drawName
                break
            is keyArrowRight
                dcgrColor(nerdClr[nerdPlayer])
                drawSelect
                nerdPlayer = (nerdPlayer + 1) & (NUM_NERDS - 1)
                drawName
                break
            is 'P'
                return TRUE
            is 'Q'
                return FALSE
            is 'I'
                item = 1
                info
                break
            is 'S'
                scores
                item = 2
                break
            is 'T' // Hidden dedications
                thankyou
                break
            is 'D'
                nerdPlayer = NUM_NERDS // Signal demo mode
                return TRUE
            is keyArrowDown
                dcgrColor(CLR_BLACK)
                drawItem(item)
                item++; if item > 3; item = 0; fin
                break
            is keyArrowUp
                dcgrColor(CLR_BLACK)
                drawItem(item)
                if item == 0; item = 3; else item--; fin
                break
            is keyEnter
                when item
                    is 0; return TRUE
                    is 1; info; break
                    is 2; scores; break
                    is 3; return FALSE
                wend
        wend
        pulse++
    loop
    return FALSE
end
//
// Splash Screen
//
def randomize#0
    conio:rnd()
    if (^$C061 | ^$C062) & $80 // Look for joystick button pushed
        musicStop
    fin
end
//
// Hook CYA IRQ handler into ProDOS IRQ chain
//
params.0 = 2
params.1 = 3
params:2 = @serviceCYA
syscall($40, @params)
//
// Automatic joystick enable/calibration
//
joyLeft, joyRight, joyUp, joyDown = joyCalibrate
dhgrMode(DHGR_COLOR_MODE)
arg = argNext(argFirst)
while ^arg and ^(arg + 1) == '-'
    when toupper(^(arg + 2))
        is 'S' // Splash screen
            //
            // Play opening sequence
            //
            screenRead("SPLASH.DHGR")
            spriteList = musicRead("GG.SEQ")
            musicPlay(spriteList, FALSE)
            musicGetKey(8, @randomize)
            heapRelease(spriteList)
            spriteList = NULL
            break
        is 'L'
            //
            // Override level
            //
            ^(arg + 2) = ^arg - 2
            level = NUM_LEVELS+1 - atoi(arg + 2)
            if level > NUM_LEVELS; level = 0; fin
            break
        is 'R'
            nerdRandomize = TRUE
            break
    wend
    arg = argNext(arg)
loop
loadLeaderBoard
loadTiles
loadSprites
if tileList <> NULL and spriteList <> NULL
    //
    // Run, Rinse, Repeat
    //
    while menu
        totalScore = 0
        quit       = FALSE
        while level and not quit
            playGG
            level--
        loop
        if not updateLeaderBoard
            rndQuote
        fin
        level = NUM_LEVELS
    loop
fin
dhgrMode(DHGR_TEXT_MODE)
//
// Detach interrupts
//
params.0 = 1
params.1 = 0
syscall($41, @params)
puts("Memory free: "); puti(heapAvail); puts(" bytes\n")
return 0
done
