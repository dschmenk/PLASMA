def drawStatus#0
    char[4] str
    var chalkboard

    itoa(@str, hoard)
    chalkboard = tileList+(TILE_CHALKBOARD-1)*TILE_SIZE
    dcgrColor(CLR_WHITE)
    //dhgrMemBl7(4*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, chalkboard, TILE_SPAN)
    //dhgrMemBl7(5*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, chalkboard, TILE_SPAN)
    dhgrMemBl7(6*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, chalkboard, TILE_SPAN)
    dcgrStr(46, 15, "Remaining:")
    dcgrStr(86, 15, @str)
end
def drawScore(nerd)#0
    char[4] str

    itoa(@str, nerdScore[nerd])
    dhgrMemBl7(0, (nerd * 2 + 1)*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_BOX-1)*TILE_SIZE, TILE_SPAN)
    dcgrColor(CLR_BLACK)
    dcgrBoldStr(nerdClr[nerd], nerdScore[nerd] > 9 ?? 4 :: 6, ((nerd+1)*2)*TILE_HEIGHT-14, @str)
end
def drawMap#0
    var i, j, k, l

    for j = TILEMAP_HEIGHT/2-1 downto 0
        for i = TILEMAP_WIDTH/2-1 downto 0
            l = TILEMAP_WIDTH-1 - i
            k = TILEMAP_HEIGHT-1 - j
            dhgrMemBl7(i*TILE_WIDTH7, j*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[j,i]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(l*TILE_WIDTH7, j*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[j,l]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(i*TILE_WIDTH7, k*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[k,i]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(l*TILE_WIDTH7, k*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[k,l]-1)*TILE_SIZE, TILE_SPAN)
        next
    next
end
def hitCheck(nerd, x, y)
    byte i

    when tileMap.[y, x]
        is TILE_FLOOR
            //
            // Check for other nerds
            //
            for i = 0 to NUM_NERDS-1
                if x == nerdX[i] and y == nerdY[i]; return TRUE; fin
            next
            return FALSE
        is TILE_BOX
            //
            // Drop off booty?
            //
            if y == nerd * 2 + 1 and nerdBooty[nerd]
                nerdBooty[nerd] = 0
                nerdScore[nerd]++
                drawScore(nerd)
                if hoard == 0
                    game = FALSE
                fin
            fin
            break
        is TILE_SEAN1
        is TILE_SEAN2
            //
            // Jackpot?
            //
            if nerdBooty[nerd] == JACKPOT
                nerdBooty[nerd] = 0
                nerdScore[nerd] = nerdScore[nerd] + 3
                drawScore(nerd)
                if hoard == 0
                    game = FALSE
                fin
            fin
            break
    wend
    return TRUE
end
def moveNerd(nerd, dir)
    byte oldX, oldY
    var moved
    byte[TILE_SIZE] tileNerd

    oldX  = nerdX[nerd]
    oldY  = nerdY[nerd]
    moved = TRUE
    when dir
        is MOVE_UP
            if hitCheck(nerd, nerdX[nerd], nerdY[nerd] - 1)
                moved = FALSE
            else
                nerdY[nerd]--
            fin
            nerdDir[nerd] = LOOK_AWAY
            break
        is MOVE_LEFT
            if nerdX[nerd] < 1 or hitCheck(nerd, nerdX[nerd] - 1, nerdY[nerd])
                moved = FALSE
            else
                nerdX[nerd]--
            fin
            nerdDir[nerd] = LOOK_LEFT
            break
        is MOVE_RIGHT
            if nerdX[nerd] >= 9 or hitCheck(nerd, nerdX[nerd] + 1, nerdY[nerd])
                moved = FALSE
            else
                nerdX[nerd]++
            fin
            nerdDir[nerd] = LOOK_RIGHT
            break
        is MOVE_DOWN
            if nerdY[nerd] >= 7 or hitCheck(nerd, nerdX[nerd], nerdY[nerd] + 1)
                moved = FALSE
            else
                nerdY[nerd]++
            fin
            nerdDir[nerd] = LOOK_FORWARD
            break
    wend
    dhgrSurfMem(OP_SRC, TILE_HEIGHT, @tileNerd, TILE_SPAN)
    dcgrColor(CLR_LTBLUE)
    dhgrClearBl7(0, 0, TILE_WIDTH7, TILE_HEIGHT)
    dcgrPixMap(0, 2, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (HORDE_BASE + nerd*NUM_NERDS + nerdDir[nerd])*SPRITE_SIZE)
    if nerdBooty[nerd]
        dcgrPixMap(0, 0, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (nerdBooty[nerd] + HOARD_BASE)*SPRITE_SIZE)
    fin
    dhgrSurfScr(OP_SRC)
    if oldX <> nerdX[nerd] or oldY <> nerdY[nerd]
        dcgrColor(CLR_LTBLUE)
        dhgrClearBl7(oldX * TILE_WIDTH7, oldY * TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT)
    fin
    dhgrMemBl7(nerdX[nerd] * TILE_WIDTH7,   \
                nerdY[nerd] * TILE_HEIGHT,  \
                TILE_WIDTH7,                \
                TILE_HEIGHT,                \
                @tileNerd,                  \
                TILE_SPAN)
    //dhgrMemBl7(oldX * TILE_WIDTH7,                                  \
    //            oldY * TILE_HEIGHT,                                 \
    //            TILE_WIDTH7,                                        \
    //            TILE_HEIGHT,                                        \
    //            tileList + (tileMap.[oldY, oldX] - 1)*TILE_SIZE,    \
    //            TILE_SPAN)
    //dcgrPixMap(nerdX[nerd] * TILE_WIDTH,        \
    //            nerdY[nerd] * TILE_HEIGHT + 2,  \
    //            SPRITE_WIDTH,                   \
    //            SPRITE_HEIGHT,                  \
    //            spriteList + (HORDE_BASE + nerd*NUM_NERDS + nerdDir[nerd])*SPRITE_SIZE)
    //if nerdBooty[nerd]
    //    dcgrPixMap(nerdX[nerd] * TILE_WIDTH,    \
    //            nerdY[nerd] * TILE_HEIGHT + 6,  \
    //            SPRITE_WIDTH,                   \
    //            SPRITE_HEIGHT,                  \
    //            spriteList + (nerdBooty[nerd] + HOARD_BASE)*SPRITE_SIZE)
    //fin
    return moved
end
def playGG#0
    byte nerd, moveDir, try
    byte joyEn, joyX, joyY, btn0, btn1, buzz
    byte joyLeft, joyRight, joyUp, joyDown
    var[NUM_NERDS] update

    //
    // Automatic joystick enable/calibration
    //
    joyEn  = FALSE
    joyX, joyY, btn0, btn1 = joyPos(0)
    if joyX < MAX_JOY and joyY < MAX_JOY
        joyEn    = TRUE
        joyLeft  = joyX / 2
        joyRight = (joyX + MAX_JOY) / 2
        joyUp    = joyY / 2
        joyDown  = (joyY + MAX_JOY) / 2 
    fin
    //
    // Intitialize level
    //
    for nerd = 0 to NUM_NERDS-1
        nerdX[nerd]     = 1
        nerdY[nerd]     = nerd * 2 + 1
        nerdBooty[nerd] = 0
        nerdScore[nerd] = 0
        drawScore(nerd)
        update[nerd]    = conio:rnd() % (level * LEVEL_SCALE)
        moveNerd(nerd, MOVE_NONE)
    next
    update[nerdPlayer] = level
    hoard              = 12
    drawStatus
    buzz               = 0
    game               = TRUE
    while game
        if buzz; buzz = ((buzz + 1) & 63) + 1; fin
        joyX, joyY, btn0, btn1 = joyPos(buzz)
        for nerd = 0 to NUM_NERDS-1
            if update[nerd]
                update[nerd]--
            else
                if nerd == nerdPlayer
                    moveDir = MOVE_NONE
                    if joyEn
                        if joyX < joyLeft
                            moveDir = MOVE_LEFT
                        elsif joyX > joyRight
                            moveDir = MOVE_RIGHT
                        fin
                        if joyY < joyUp
                            moveDir = MOVE_UP
                        elsif joyY > joyDown
                            moveDir = MOVE_DOWN
                        fin
                    fin
                    if conio:keypressed()
                        when toupper(conio:getkey())
                            is 'I'
                            is keyArrowUp
                                moveDir = MOVE_UP
                                break
                            is 'J'
                            is keyArrowLeft
                                moveDir = MOVE_LEFT
                                break
                            is 'K'
                            is keyArrowRight
                                moveDir = MOVE_RIGHT
                                break
                            is 'M'
                            is keyArrowDown
                                moveDir = MOVE_DOWN
                                break
                            is 'B'
                                hoard--
                                drawStatus
                                nerdBooty[nerdPlayer]++
                                if nerdBooty[nerdPlayer] > HOARD_NUM; nerdBooty[nerdPlayer] = 0; fin
                                moveNerd(nerdPlayer, MOVE_NONE)
                                break
                            is 'P'
                                nerdPlayer++
                                if nerdPlayer >= NUM_NERDS; nerdPlayer = 0; fin
                                break
                            is 'S'
                                if buzz; buzz = 0; else buzz = 1; fin
                                break
                            is '1'
                                level = 9
                                break
                            is '2'
                                level = 8
                                break
                            is '3'
                                level = 7
                                break
                            is '4'
                                level = 6
                                break
                            is '5'
                                level = 5
                                break
                            is '6'
                                level = 4
                                break
                            is '7'
                                level = 3
                                break
                            is '8'
                                level = 2
                                break
                            is '9'
                                level = 1
                                break
                            is '0'
                                level = 0
                                break
                            is keyEscape
                                game = FALSE
                        wend
                        moveNerd(nerdPlayer, moveDir)
                    fin
                    update[nerdPlayer] = level
                else // Move NPC
                     moveNerd(nerd, conio:rnd() & MOVE_MASK)
                    update[nerd] = (level * LEVEL_SCALE)
                fin
            fin
        next
    loop
end
def info#0
    screenRead("GG.DHGR")
    getc
    drawMenu
end
def nerdNext#0
    dcgrColor(CLR_AQUA)
    drawSelect
    nerdPlayer = (nerdPlayer + 1) & (NUM_NERDS - 1)
end
def menu
    byte item, pulse

    drawMenu
    item = 0
    while TRUE
        dcgrColor(pulse)
        drawItem(item)
        drawSelect
        if conio:keypressed()
            when toupper(getc)
                is 'P'
                    return TRUE
                is 'Q'
                    return FALSE
                is 'I'
                    dcgrColor(CLR_BLACK)
                    drawItem(item)
                    item = 1
                    info
                    break
                is keyArrowLeft
                    dcgrColor(CLR_BLACK)
                    drawItem(item)
                    item = 2
                    dcgrColor(CLR_AQUA)
                    drawSelect
                    nerdPlayer = (nerdPlayer - 1) & (NUM_NERDS - 1)
                    break
                is keyArrowRight
                is 'N'
                    dcgrColor(CLR_BLACK)
                    drawItem(item)
                    item = 2
                    nerdNext
                    break
                is 'S'
                    dcgrColor(CLR_BLACK)
                    drawItem(item)
                    item = 3
                    break
                is keyArrowDown
                    dcgrColor(CLR_BLACK)
                    drawItem(item)
                    item++; if item > 4; item = 0; fin
                    break
                is keyArrowUp
                    dcgrColor(CLR_BLACK)
                    drawItem(item)
                    if item == 0; item = 4; else item--; fin
                    break
                is keyEnter
                    when item
                        is 0
                            return TRUE
                        is 1
                            info
                            break
                        is 2
                            nerdNext
                            break
                        is 4
                            return FALSE
                    wend
            wend
        fin
        pulse++
    loop
    return FALSE
end
def randomize#0
    conio:rnd()
end
//
// Import test harness
//
arg = argNext(argFirst)
while ^arg
    arg = argNext(arg)
loop
dhgrMode(DHGR_COLOR_MODE)
//screenRead("SPLASH.DHGR")
//
// Hook CYA IRQ handler into ProDOS IRQ chain
//
params.0 = 2
params.1 = 3
params:2 = @serviceCYA
syscall($40, @params)
//
// Play opening sequence
//
//arg = musicRead("GG.SEQ")
//musicPlay(arg, FALSE)
//musicGetKey(8, @randomize)
//heaprelease(arg)
dcgrFont(FONT_DEF_THIN)
loadTiles
loadSprites
if tileList <> NULL and spriteList <> NULL
    //screenRead("MENU.DHGR")
    //getc
    level = 9
    while menu
        drawMap
        playGG
    loop
fin
dhgrMode(DHGR_TEXT_MODE)
//
// Detach interrupts
//
params.0 = 1
params.1 = 0
syscall($41, @params)
puts("Memory free: "); puti(heapAvail); puts(" bytes\n")
return 0
done
