//
// Debug
//
def assert(val, msg)#0
    if not val
        dhgrMode(DHGR_TEXT_MODE)
        puts(msg)
        getc
    fin
end
//
// String utilities
//
def strcati(str, i)#0
    if i >= 10; strcati(str, i / 10); fin
    ^str++
    ^(str + (^str)) = (i % 10 + '0')
end
def itoa(str, i)#1
    ^str = 0
    if i < 0; ^str = 1; ^(str+1) = '-'; i = -i; fin
    strcati(str, i)
    return str
end
//
// Load assets
//
def loadTiles#0
    byte refnum

    refnum = fileio:open("TILES")
    if refnum
        tileList = heapAlloc(TILE_SIZE*NUM_TILES)
        if tileList and fileio:read(refnum, tileList, TILE_SIZE*NUM_TILES) <> TILE_SIZE*NUM_TILES
            heapRelease(tileList)
            tileList = NULL
            puts("Error reading tiles\n")
        fin
        fileio:close(refnum)
    fin
end
def loadSprites#0
    byte refnum

    refnum = fileio:open("SPRITES")
    if refnum
        spriteList = heapAlloc(SPRITE_SIZE*NUM_SPRITES)
        if spriteList and fileio:read(refnum, spriteList, SPRITE_SIZE*NUM_SPRITES) <> SPRITE_SIZE*NUM_SPRITES
            heapRelease(spriteList)
            spriteList = NULL
            puts("Error reading sprites\n")
        fin
        fileio:close(refnum)
    fin
end
//
// Sound F/X Action
//
def actionSFX(event)#0
    byte sfxTable, sfxIndex

    sfxIndex = event->evParam.1
    sfxTable = event->evParam.0
    buzz = sfxList.[sfxTable, sfxIndex]
    if buzz
        event->evParam.1 = sfxIndex + 1
        addEvent(1, event)
    else
        eventFree(event)
    fin
end
//
// Drawing utilites
//
def drawInfo#0
    var bl7ptr, span
    byte refnum
    byte strX, strY, extX, extY
    byte h, v
    var strInfo

    dcgrColor(CLR_GREEN)
    dhgrClearBl7(0, 0, SCR_WIDTH7, SCR_HEIGHT)
    bl7ptr, span = dhgrAllocBl7Mem(SCR_WIDTH, 92)
    if bl7ptr
        refnum = fileio:open("GGINFO.IMG")
        if refnum
            fileio:read(refnum, bl7ptr, span*92)
            fileio:close(refnum)
        fin
        dhgrMemBl7(0,  0, span/4, 92, bl7ptr, span)
        heapRelease(bl7ptr)
    fin
    dcgrFont(fontGG)
    strInfo = @infoText
    strY    = 100
    while ^strInfo and strY < 192
        extX, extY = dcgrStrExtents(strInfo)
        strX = 70 - (extX + 1)/2
        dcgrColor(CLR_BLACK)
        dcgrRect(strX - 1, strY - extY + 1, extX + 4, extY + 2)
        dcgrRect(strX - 2, strY - extY + 2, extX + 6, extY)
        dcgrColor(CLR_WHITE)
        dcgrStr(strX, strY, strInfo)
        strY = strY + extY + 2// 12
        strInfo = strInfo + ^strInfo + 1
    loop
end
def drawFrame(x, y, w, h)#0
    byte r, b

    b = y+h-1
    r = x+w-1
    dcgrVLin(y, b, x)
    dcgrVLin(y, b, r)
    dcgrHLin(x, r, y)
    dcgrHLin(x, r, b)
end  
def drawItem(item)#0
    when item
        is 0
            dcgrStr(96,  76, "[P]lay")
            break
        is 1
            dcgrStr(96, 96, "[I]nfo")
            break
        is 2
            dcgrStr(96, 116, "[N]erd")
            break
        is 3
            dcgrStr(96, 136, "[S]cores")
            break
        is 4
            dcgrStr(96, 156, "[Q]uit")
        wend
end
def drawSelect#0
    drawFrame(nerdPlayer*TILE_WIDTH + nerdPlayer + 71, 31, SPRITE_WIDTH + 2, SPRITE_HEIGHT + 2)
end
def drawName#0
    var nameSurf

    nameSurf = heapAlloc(9*4*10)
    dhgrSurfMem(OP_SRC, 10, nameSurf, 9*4)
    dcgrColor(CLR_PINK)
    dhgrClearBl7(0, 0, 9, 10)
    dcgrColor(CLR_BLACK)
    dcgrBoldStr(nerdClr[nerdPlayer], 30 - ^nerdName[nerdPlayer] * 2, 9, nerdName[nerdPlayer])
    dhgrSurfScr(OP_SRC)
    dhgrMemBl7(10,  16, 9, 10, nameSurf, 9*4)
    heapRelease(nameSurf)
end
