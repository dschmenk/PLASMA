    itoa(@str, hoardRemaining)
    dcgrColor(CLR_WHITE)
    dhgrMemBl7(7*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_RIGHTBOARD-1)*TILE_SIZE, TILE_SPAN)
    dcgrStr(7*TILE_WIDTH, 15, @str)
end
def drawScore(nerd)#0
    char[4] str

    itoa(@str, nerdScore[nerd])
    dhgrMemBl7(0, (nerd * 2 + 1)*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_BOX-1)*TILE_SIZE, TILE_SPAN)
    dcgrColor(CLR_BLACK)
    dcgrBoldStr(nerdClr[nerd], nerdScore[nerd] > 9 ?? 4 :: 6, ((nerd+1)*2)*TILE_HEIGHT-14, @str)
end
def drawMap#0
    var i, j, k, l
    char[4] lvlStr

    for j = TILEMAP_HEIGHT/2-1 downto 0
        for i = TILEMAP_WIDTH/2-1 downto 0
            l = TILEMAP_WIDTH-1 - i
            k = TILEMAP_HEIGHT-1 - j
            dhgrMemBl7(i*TILE_WIDTH7, j*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[j,i]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(l*TILE_WIDTH7, j*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[j,l]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(i*TILE_WIDTH7, k*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[k,i]-1)*TILE_SIZE, TILE_SPAN)
            dhgrMemBl7(l*TILE_WIDTH7, k*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[k,l]-1)*TILE_SIZE, TILE_SPAN)
        next
    next
    dcgrFont(FONT_DEF_THIN)
    dcgrColor(CLR_WHITE)
    dcgrStr(46, 15, "Level")
    dcgrStr(46+24, 15, itoa(@lvlStr, 10 - level))
    dcgrStr(46+32, 15, "Left")
end
def actionSean(event)#0
    dhgrMemBl7(8*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN1-1)*TILE_SIZE, TILE_SPAN)
    dhgrMemBl7(9*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN2-1)*TILE_SIZE, TILE_SPAN)
    eventFree(event)
end
def hitCheck(nerd, x, y)#1
    byte i

    if x < 0 or x >= TILEMAP_WIDTH or y >= TILEMAP_HEIGHT; return HIT_TILE; fin // Quick test for edges
    when tileMap.[y, x]
        is TILE_FLOOR
            //
            // Check for other nerds
            //
            for i = 0 to NUM_NERDS-1
                if x == nerdX[i] and y == nerdY[i]
                    //
                    // Steal?
                    //
                    if nerd == nerdPlayer and (btn0 & btn1) & $80 and \\
                        not nerdHoard[nerd] and nerdHoard[i] and nerdScore[nerd] <= nerdScore[i]
                        nerdHoard[nerd] = nerdHoard[i]
                        nerdHoard[i]    = 0
                        addAction(1, @actionSFX, SFX_STEAL)
                        moveNerd(i, MOVE_NONE) // Draw sealee without hoard
                    else
                        addAction(1, @actionSFX, SFX_BUMP)
                    fin
                    return HIT_NERD
                fin
            next
            return HIT_NOTHING
        is TILE_BOX
            //
            // Drop off hoard?
            //
            if y == nerd * 2 + 1 and nerdHoard[nerd]
                hoardActive--
                nerdHoard[nerd] = 0
                nerdScore[nerd]++
                drawScore(nerd)
                addAction(1, @actionSFX, SFX_SCORE)
            fin
            break
        is TILE_SEAN1
        is TILE_SEAN2
            //
            // Jackpot?
            //
            if nerdHoard[nerd] == JACKPOT
                hoardActive--
                nerdHoard[nerd] = 0
                nerdScore[nerd] = nerdScore[nerd] + 3
                drawScore(nerd)
                addAction(1, @actionSFX, SFX_JACKPOT)
                addAction(100, @actionSean, 0)
                dhgrMemBl7(8*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN3-1)*TILE_SIZE, TILE_SPAN)
                dhgrMemBl7(9*TILE_WIDTH7, 0, TILE_WIDTH7, TILE_HEIGHT, tileList+(TILE_SEAN4-1)*TILE_SIZE, TILE_SPAN)
            fin
            break
        is TILE_TABLE1
        is TILE_TABLE2
        is TILE_TABLE3
        is TILE_TABLE4
            for i = 0 to TABLE_POSITIONS-1
                if tablePosX[i] == x and tablePosY[i] == y; break; fin
            next
            if hoardType[i] // Pick up HW
                dhgrMemBl7(x*TILE_WIDTH7, y*TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, tileList+(tileMap.[y,x]-1)*TILE_SIZE, TILE_SPAN)
                nerdHoard[nerd], hoardType[i] = hoardType[i], nerdHoard[nerd] // Swap goods
                if hoardType[i]
                    dcgrPixMap(tablePosX[i] * TILE_WIDTH,       \
                                tablePosY[i] * TILE_HEIGHT + 2, \
                                SPRITE_WIDTH, SPRITE_HEIGHT,    \
                                spriteList + (hoardType[i] - 1) * SPRITE_SIZE)
                else
                    hoardAvailable--
                fin
                addAction(1, @actionSFX, SFX_PICKUP)
            fin
    wend
    return HIT_TILE
end
def mapZone(x, y)#1
    byte zone

    zone = 0
    if x < 3 or (x == 3 and y == 4) // Include end of table
        zone = ZONE_WEST
    elsif x > 7 or (x == 7 and y == 4) // Include side of table
        zone = ZONE_EAST
    fin
    if y < 3 or (y == 3 and (x > 3 and x < 7)) // Include middle-top row of table
        zone = zone | ZONE_NORTH
    elsif y > 5 or (y == 5 and (x > 3 and x < 7)) // Include middle-bottom row of table
        zone = zone | ZONE_SOUTH
    fin
    return zone
end
def moveNerd(nerd, dir)#1
    byte oldX, oldY
    var moved
    byte[TILE_SIZE] tileNerd

    oldX  = nerdX[nerd]
    oldY  = nerdY[nerd]
    moved = FALSE
    when dir
        is MOVE_UP
            if not hitCheck(nerd, nerdX[nerd], nerdY[nerd] - 1)
                nerdY[nerd]--
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_AWAY
            break
        is MOVE_LEFT
            if nerdX[nerd] > 0 and not hitCheck(nerd, nerdX[nerd] - 1, nerdY[nerd])
                nerdX[nerd]--
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_LEFT
            break
        is MOVE_RIGHT
            if nerdX[nerd] < 9 and not hitCheck(nerd, nerdX[nerd] + 1, nerdY[nerd])
                nerdX[nerd]++
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_RIGHT
            break
        is MOVE_DOWN
            if nerdY[nerd] < 7 and not hitCheck(nerd, nerdX[nerd], nerdY[nerd] + 1)
                nerdY[nerd]++
                moved = TRUE
            fin
            nerdDir[nerd] = LOOK_FORWARD
            break
    wend
    //
    // Draw nerd + any hoard to memory surface the size of a tile
    //
    dhgrSurfMem(OP_SRC, TILE_HEIGHT, @tileNerd, TILE_SPAN)
    dcgrColor(CLR_LTBLUE)
    dhgrClearBl7(0, 0, TILE_WIDTH7, TILE_HEIGHT)
    dcgrPixMap(0, 2, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (HORDE_BASE + nerd*NUM_NERDS + nerdDir[nerd])*SPRITE_SIZE)
    if nerdHoard[nerd]
        dcgrPixMap(0, 0, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (nerdHoard[nerd] + HOARD_BASE)*SPRITE_SIZE)
    fin
    dhgrSurfScr(OP_SRC)
    if moved
        //
        // Erase previous position
        //
        dcgrColor(CLR_LTBLUE)
        dhgrClearBl7(oldX * TILE_WIDTH7, oldY * TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT)
    fin
    //
    // Update nerd on screen
    //
    dhgrMemBl7(nerdX[nerd] * TILE_WIDTH7,  nerdY[nerd] * TILE_HEIGHT, TILE_WIDTH7, TILE_HEIGHT, @tileNerd, TILE_SPAN)
    return moved
end
def addHoard#0
    byte pos

    if hoardRemaining and hoardAvailable < TABLE_POSITIONS
        pos = conio:rnd() % TABLE_POSITIONS
        while hoardType[pos]
            pos++; if pos >= TABLE_POSITIONS; pos = 0; fin
        loop
        if hoardJackpots
            if hoardJackpots >= hoardRemaining
                hoardType[pos] = JACKPOT
            else
                hoardType[pos] = ((conio:rnd() & 255) < 25) ?? JACKPOT :: (conio:rnd() & HOARD_NUM-2) + 1
            fin
            if hoardType[pos] == JACKPOT
                hoardJackpots--
            fin
        else
            hoardType[pos] = (conio:rnd() & HOARD_NUM-2) + 1
        fin
        hoardActive++
        hoardAvailable++
        hoardRemaining--
        dcgrPixMap(tablePosX[pos] * TILE_WIDTH, tablePosY[pos]*TILE_HEIGHT+2, SPRITE_WIDTH, SPRITE_HEIGHT, spriteList + (hoardType[pos] - 1) * SPRITE_SIZE)
        drawStatus
    fin
end
//
// Actions
//
def actionUpdateHoard(event)#0
    //
    // Add hoard to table at random time
    //
    addHoard
    if hoardRemaining
        addEvent(conio:rnd() % ((level + 1) * HOARD_SCALE), event)
    else
        eventFree(event)
    fin
end
def actionUpdateNerd(event)#0
    byte nerd, moveDir, i
    byte targetX, targetY, nerdZone, targetZone
    var nearest, dist, distX, distY

    //
    // Move NPC
    //
    nerd = event->evParam
    if nerdHoard[nerd]
        //
        // Head for NPCs collection box unless jackpot
        //
        if nerdHoard[nerd] == JACKPOT
            targetX = 8
            targetY = 0
        else
            targetX = 0
            targetY = nerd * 2 + 1
        fin
    else
        //
        // Head for nearest table position with booty
        //
        nearest = 1000
        for i = 0 to TABLE_POSITIONS-1
            if hoardType[i]
                if hoardType[i] == JACKPOT // Always go for the jackpot
                    nearest = 0
                    targetX = tablePosX[i]
                    targetY = tablePosY[i]
                    break
                fin
                distX = tablePosX[i] - nerdX[nerd]
                distY = tablePosY[i] - nerdY[nerd]
                dist  = distX * distX + distY * distY
                if dist < nearest
                    nearest = dist
                    targetX = tablePosX[i]
                    targetY = tablePosY[i]
                fin
            fin
        next
        if nearest == 1000
            //
            // Wander aimlessly with nothing to go for
            //
            targetX = conio:rnd() % TILEMAP_WIDTH
            targetY = conio:rnd() % TILEMAP_HEIGHT
        fin
    fin
    //
    // Find best way to target
    //
    distX      = targetX - nerdX[nerd]
    distY      = targetY - nerdY[nerd]
    nerdZone   = mapZone(nerdX[nerd], nerdY[nerd])
    targetZone = mapZone(targetX, targetY)
    when nerdZone & targetZone
        is ZONE_EAST
        is ZONE_WEST
            //
            // Both on same side - prioritize up/down
            //
            if distY == 0
                moveDir = distX < 0 ?? MOVE_LEFT :: MOVE_RIGHT
            else
                moveDir = distY < 0 ?? MOVE_UP :: MOVE_DOWN
            fin
            break
        is ZONE_NORTH
        is ZONE_SOUTH
            //
            // Both on same side - prioritize left/right
            //
            if distX == 0
                moveDir = distY < 0 ?? MOVE_UP :: MOVE_DOWN
            else
                moveDir = distX < 0 ?? MOVE_LEFT :: MOVE_RIGHT
            fin
            break
        otherwise
            //
            // Have to move around table
            //
            if nerdZone == ZONE_EAST or nerdZone == ZONE_WEST
                moveDir = targetY < TILEMAP_HEIGHT/2 ?? MOVE_UP :: MOVE_DOWN
            elsif nerdZone == ZONE_NORTH or nerdZone == ZONE_SOUTH
                moveDir = targetX < TILEMAP_WIDTH/2 ?? MOVE_LEFT :: MOVE_RIGHT
            elsif distX * distX > distY * distY
                moveDir = distX < 0 ??  MOVE_LEFT :: MOVE_RIGHT
            else
                moveDir = distY < 0 ?? MOVE_UP :: MOVE_DOWN                    
            fin
    wend
    if not moveNerd(nerd, moveDir) and (distX * distX + distY * distY) > 1
        moveNerd(nerd, conio:rnd() & MOVE_MASK) // Help get unstuck
    fin
    addEvent(level * HORDE_SCALE + HORDE_EQ, event)
end
def joyCalibrate#4
    byte x, y

    x, y, drop, drop = joyPos(0)
    if x < MAX_JOY and y < MAX_JOY
        return x / 2, (x + MAX_JOY) / 2, y / 2, (y + MAX_JOY) / 2 
    fin
    return 0, 0, MAX_JOY, MAX_JOY
end
def actionUpdatePlayer(event)#0
    byte moveDir

    moveDir = MOVE_NONE
    if joyX < joyLeft
        moveDir = MOVE_LEFT
    elsif joyX > joyRight
        moveDir = MOVE_RIGHT
    fin
    if joyY < joyUp
        moveDir = MOVE_UP
    elsif joyY > joyDown
        moveDir = MOVE_DOWN
    fin
    if conio:keypressed()
        when toupper(conio:getkey())
            is keyArrowUp
                moveDir = MOVE_UP
                break
            is keyArrowLeft
                moveDir = MOVE_LEFT
                break
            is keyArrowRight
                moveDir = MOVE_RIGHT
                break
            is keyArrowDown
                moveDir = MOVE_DOWN
                break
            is 'C' // Recalibrate joystick on the fly
                joyLeft, joyRight, joyUp, joyDown = joyCalibrate
                break
            is 'P' // Pause
                drawMessage("Paused...")
                getc
                drawMessage(NULL)
                break
            is keyEscape
                hoardActive = 0; hoardRemaining = 0; exit = TRUE
        wend
    fin
    moveNerd(nerdPlayer, moveDir)
    addEvent(PLAYER_EQ, event)
end
def actionDemo(event)#0
    if conio:keypressed()
        when toupper(conio:getkey())
            is keyEscape
                hoardActive = 0; hoardRemaining = 0; exit = TRUE
        wend
    fin
    addEvent(PLAYER_EQ, event)
end
def playGG#0
    //
    // Initialize event system
    //
    eventInit
    //
    // Show playing field
    //
    drawMap
    //
    // Intitialize horde
    //
    for buzz = 0 to NUM_NERDS-1
        nerdX[buzz]     = 1
        nerdY[buzz]     = buzz * 2 + 1
        nerdHoard[buzz] = 0
        nerdScore[buzz] = 0
        drawScore(buzz)
        moveNerd(buzz, MOVE_NONE)
        if buzz == nerdPlayer
            addAction(PLAYER_EQ, @actionUpdatePlayer, buzz)
        else
            addAction(conio:rnd() % (level * HORDE_SCALE + HORDE_EQ), @actionUpdateNerd, buzz)
        fin
    next
    if nerdPlayer > 3; addAction(1, @actionDemo, 0); fin
    //
    // Initialize hoard
    //
    for buzz = 0 to TABLE_POSITIONS-1
        hoardType[buzz] = 0
    next
    hoardActive    = 0
    hoardAvailable = 0
    hoardRemaining = HOARD_SIZE
    hoardJackpots  = hoardRemaining / 10
    addHoard
    addHoard
    addHoard
    addHoard
    addAction((level + 1) * HOARD_SCALE, @actionUpdateHoard, 0)
    //
    // Go!
    //
    drawMessage("Ready...")
    conio:tone(50, 40)
    drawMessage("Set...")
    conio:tone(50, 40)
    drawMessage("Go!")
    conio:tone(60, 10)
    drawMessage(NULL)
    buzz = 0
    while hoardActive or hoardRemaining
        //
        // Sound/joystick
        //
        joyX, joyY, btn0, btn1 = joyPos(buzz)
        //
        // Check event queue
        //
        doEvents
    loop
    totalScore = totalScore + nerdScore[nerdPlayer] // Add to total score
    drawMessage(exit ?? "Quitter!" :: level == 1 ?? "Finished!" :: "Next Level!")
    conio:tone(30, 20)
    conio:tone(200, 10)
    for hoardActive = 255 downto 0
        for hoardAvailable = 7 downto 0
            if conio:keypressed(); conio:getkey(); return ;fin
        next
    next
end
//
// Top scores
//
def loadLeaderBoard#0
    byte refnum

    refnum = fileio:open(@leaderName)
    if refnum
        fileio:read(refnum, @leaderBoard, t_leaders*10)
        fileio:close(refnum)
    fin
end
def storeLeaderBoard#0
    byte refnum

    if updateLeaders
        fileio:destroy(@leaderName)
        fileio:create(@leaderName, $06, $0000)
        refnum = fileio:open(@leaderName)
        if refnum
            fileio:write(refnum, @leaderBoard, t_leaders*10)
            fileio:close(refnum)
        fin
    fin
end
def updateLeaderBoard#0
    byte pulse, pos, key
    var leader
    byte[2] initial

    for leader = 0 to 9
        if leaderBoard[leader * t_leaders + 3] < totalScore; break; fin
    next
    if leader == 10 or nerdPlayer > 3; return; fin
    updateLeaders = TRUE
    memcpy(@leaderBoard + (leader + 1) * t_leaders, @leaderBoard + leader * t_leaders, (9 - leader) * t_leaders)
    leader = @leaderBoard + leader * t_leaders
    leader->[0] = '_'
    leader->[1] = '_'
    leader->[2] = '_'
    leader->[3] = totalScore
    dcgrColor(CLR_BLACK)
    dhgrClearBl7(3*TILE_WIDTH7, 3*TILE_HEIGHT, TILE_WIDTH7*5, TILE_HEIGHT*3)
    dcgrFont(FONT_DEF_THIN)
    dcgrColor(CLR_AQUA)
    dcgrBoldStr(CLR_MAGENTA, 5*TILE_WIDTH+TILE_WIDTH/2 - 15 * 2, 5*TILE_HEIGHT - 28, "Enter Initials")
    dcgrColor(CLR_WHITE)
    dcgrStr(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2, 5*TILE_HEIGHT - 8, "_ _ _")
    initial[0] = 1
    initial[1] = leader->[0]
    pos        = 0
    repeat
        dcgrColor(pulse)
        dcgrStr(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 8, @initial)
        pulse++
        key = 0
        if conio:keypressed()
            key = toupper(getc)
            if key >= 'A' and key <= 'Z'
                initial[1] = key
                dcgrColor(CLR_BLACK)
                dcgrRect(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 16, 4, 8)
                dcgrColor(CLR_WHITE)
                dcgrStr(5*TILE_WIDTH+TILE_WIDTH/2 - 4 * 2 + pos * 8, 5*TILE_HEIGHT - 8, @initial)
                leader->[pos] = key
                pos++
                if pos > 2; pos = 0; fin
                initial[1] = leader->[pos]
            fin
        fin
    until key == keyEnter
end
//
// Menu interface
//
def randomize#0
    conio:rnd()
    if (^$C061 | ^$C062) & $80 // Look for joystick button pushed
        getc
        musicStop
    fin
end
def info#0
    drawInfo
    getc
    drawMenu
end
def nerdNext#0
    dcgrColor(CLR_AQUA)
    drawSelect
    nerdPlayer = (nerdPlayer + 1) & (NUM_NERDS - 1)
    drawName
end
def scores#0
    drawLeaderBoard
    getc
    drawMenu
end
def menu
    byte item, pulse, key

    if nerdPlayer > 3; nerdPlayer = 3; fin
    drawMenu
    item = 0
    while TRUE
        dcgrColor(pulse >> 1)
        drawItem(item)
        drawSelect
        //
        // Handle user input
        //
        key = 0
        if conio:keypressed()
            key = toupper(getc)
        else
            joyX, joyY, btn0, btn1 = joyPos(0)
            if joyX < joyLeft
                key = keyArrowLeft
            elsif joyX > joyRight
                key = keyArrowRight
            fin
            if joyY < joyUp
                key = keyArrowUp
            elsif joyY > joyDown
                key = keyArrowDown
            fin
            if btn0 or btn1
                key = keyEnter
            fin
        fin
        when key
            is 'P'
                return TRUE
            is 'Q'
                return FALSE
            is 'I'
                dcgrColor(CLR_BLACK)
                drawItem(item)
                item = 1
                info
                break
            is keyArrowLeft
                dcgrColor(CLR_BLACK)
                drawItem(item)
                item = 2
                dcgrColor(CLR_AQUA)
                drawSelect
                nerdPlayer = (nerdPlayer - 1) & (NUM_NERDS - 1)
                drawName
                break
            is keyArrowRight
            is 'N'
                dcgrColor(CLR_BLACK)
                drawItem(item)
                item = 2
                nerdNext
                break
            is 'S'
                scores
                item = 3
                break
            is 'D'
                nerdPlayer = 4
                return TRUE
            is keyArrowDown
                dcgrColor(CLR_BLACK)
                drawItem(item)
                item++; if item > 4; item = 0; fin
                break
            is keyArrowUp
                dcgrColor(CLR_BLACK)
                drawItem(item)
                if item == 0; item = 4; else item--; fin
                break
            is keyEnter
                when item
                    is 0; return TRUE
                    is 1; info; break
                    is 2; nerdNext; break
                    is 3; scores; break
                    is 4; return FALSE
                wend
        wend
        pulse++
    loop
    return FALSE
end
//
// Hook CYA IRQ handler into ProDOS IRQ chain
//
params.0 = 2
params.1 = 3
params:2 = @serviceCYA
syscall($40, @params)
dhgrMode(DHGR_COLOR_MODE)
arg = argNext(argFirst)
while ^arg and ^(arg + 1) == '-'
    when toupper(^(arg + 2))
        is 'S' // Splash screen
            //
            // Play opening sequence
            //
            screenRead("SPLASH.DHGR")
            spriteList = musicRead("GG.SEQ")
            musicPlay(spriteList, FALSE)
            musicGetKey(8, @randomize)
            heapRelease(spriteList)
            spriteList = NULL
            break
        is 'L'
            //
            // Override level
            //
            level = 10 - (^(arg + 3) - '0')
            if level > 9; level = 0; fin
            break
    wend
    arg = argNext(arg)
loop
fontGG = fontRead("GG.FON")
loadLeaderBoard
loadTiles
loadSprites
if tileList <> NULL and spriteList <> NULL
    //
    // Automatic joystick enable/calibration
    //
    joyLeft, joyRight, joyUp, joyDown = joyCalibrate
    //
    // Run, Rinse, Repeat
    //
    while menu
        totalScore = 0
        exit       = FALSE
        level      = 9
        while level and not exit
            playGG
            level--
        loop
        updateLeaderBoard
    loop
fin
storeLeaderBoard
dhgrMode(DHGR_TEXT_MODE)
//
// Detach interrupts
//
params.0 = 1
params.1 = 0
syscall($41, @params)
puts("Memory free: "); puti(heapAvail); puts(" bytes\n")
return 0
done
