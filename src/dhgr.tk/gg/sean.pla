sysflags resxtxt1|reshgr1|resxhgr1|nojitc

var arg
//
// Tiles
//
var tileList  = NULL
byte tileRow1 =  1,  2,  3,  4,  5,  5,  5,  6, 19, 20
byte tileRow2 =  8,  9,  9,  9,  9,  9,  9,  9,  9,  9
byte tileRow3 =  9,  9,  9,  9,  9,  9,  9,  9,  9,  9
byte tileRow4 =  8,  9,  9, 10, 11, 11, 11, 12,  9,  9
byte tileRow5 =  9,  9,  9, 13, 14, 14, 14, 15,  9,  9
byte tileRow6 =  8,  9,  9, 16, 17, 17, 17, 18,  9,  9
byte tileRow7 =  9,  9,  9,  9,  9,  9,  9,  9,  9,  9
byte tileRow8 =  8,  9,  9,  9,  9,  9,  9,  9,  9,  9
var tileMap   = @tileRow1, @tileRow2, @tileRow3, @tileRow4
var           = @tileRow5, @tileRow6, @tileRow7, @tileRow8 
//
// Sprites
//
var spriteList = NULL
//
// Nerds
//
const NUM_NERDS    = 4
const LOOK_FORWARD = 0
const LOOK_RIGHT   = 1
const LOOK_LEFT    = 2
const LOOK_AWAY    = 3
const MOVE_DOWN    = 0
const MOVE_RIGHT   = 1
const MOVE_LEFT    = 2
const MOVE_UP      = 3
const MOVE_NONE    = 4
const MOVE_MASK    = 3
byte nerdPlayer    = 0
byte[NUM_NERDS] nerdClr = CLR_GREEN, CLR_BROWN, CLR_GREY, CLR_ORANGE
byte[NUM_NERDS] nerdX = 2, 3, 4, 5
byte[NUM_NERDS] nerdY = 2,  2,  2,  2
byte[NUM_NERDS] nerdDir = LOOK_LEFT, LOOK_FORWARD, LOOK_FORWARD, LOOK_RIGHT
byte[NUM_NERDS] nerdBooty, nerdScore
//
// Levels
//
const LEVEL_SCALE = 10
byte level, game, hoard // Equipment
//
// This fixes the Virtual ][ bug with outstanding Mockingboard interrupts
//
byte[4] params
asm serviceCYA#0
        CLC
        RTS
end
//
// String utilities
//
def strcati(str, i)#0
    if i >= 10; strcati(str, i / 10); fin
    ^str++
    ^(str + (^str)) = (i % 10 + '0')
end
def itoa(str, i)#1
    ^str = 0
    if i < 0; ^str = 1; ^(str+1) = '-'; i = -i; fin
    strcati(str, i)
    return str
end
//
// Load assets
//
def loadTiles#0
    byte refnum

    refnum = fileio:open("TILES")
    if refnum
        tileList = heapAlloc(TILE_SIZE*NUM_TILES)
        if tileList and fileio:read(refnum, tileList, TILE_SIZE*NUM_TILES) <> TILE_SIZE*NUM_TILES
            heapRelease(tileList)
            tileList = NULL
            puts("Error reading tiles\n")
        fin
        fileio:close(refnum)
    fin
end
def loadSprites#0
    byte refnum

    refnum = fileio:open("SPRITES")
    if refnum
        spriteList = heapAlloc(SPRITE_SIZE*NUM_SPRITES)
        if spriteList and fileio:read(refnum, spriteList, SPRITE_SIZE*NUM_SPRITES) <> SPRITE_SIZE*NUM_SPRITES
            heapRelease(spriteList)
            spriteList = NULL
            puts("Error reading sprites\n")
        fin
        fileio:close(refnum)
    fin
end
def drawFrame(x, y, w, h)#0
    byte r, b

    b = y+h-1
    r = x+w-1
    dcgrVLin(y, b, x)
    dcgrVLin(y, b, r)
    dcgrHLin(x, r, y)
    dcgrHLin(x, r, b)
end  
def drawItem(item)#0
    when item
        is 0
            dcgrStr(96,  84, "[P]lay")
            break
        is 1
            dcgrStr(96, 104, "[I]nfo")
            break
        is 2
            dcgrStr(96, 124, "[N]erd")
            break
        is 3
            dcgrStr(96, 144, "[S]cores")
            break
        is 4
            dcgrStr(96, 164, "[Q]uit")
        wend
end
def drawSelect#0
    drawFrame(nerdPlayer*TILE_WIDTH + nerdPlayer + 71, 31, SPRITE_WIDTH + 2, SPRITE_HEIGHT + 2)
end
