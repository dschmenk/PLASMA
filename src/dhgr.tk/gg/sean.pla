char              = 'W', 'O', 'Z', 90
char              = 'W', 'O', 'Z', 80
char              = 'W', 'O', 'Z', 70
char              = 'W', 'O', 'Z', 60
char              = 'W', 'O', 'Z', 50
char              = 'W', 'O', 'Z', 40
char              = 'W', 'O', 'Z', 30
char              = 'W', 'O', 'Z', 20
char              = 'W', 'O', 'Z', 10
